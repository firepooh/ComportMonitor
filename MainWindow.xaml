<Window x:Class="ComportMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ComportMonitor"
        Title="COM Port Monitor"
        WindowStyle="None"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Width="280" Height="120"
        Left="1300" Top="10"
        WindowStartupLocation="Manual"
        MouseLeftButtonDown="Window_MouseLeftButtonDown"
        MouseWheel="Window_MouseWheel">
    <!-- AllowsTransparency(레이어드 창)는 모니터 DPI != 시스템 DPI일 때 HWND 크기가
         96DPI 기준으로 잡히는 WPF 버그가 있어 사용하지 않는다. 반투명은 Win11 DWM
         아크릴 백드롭(DWMWA_SYSTEMBACKDROP_TYPE)으로, 둥근 모서리는 DWM 특성으로
         처리하고 크기는 코드에서 콘텐츠를 측정해 Width/Height를 직접 설정한다.
         초기 Left/Top은 주 모니터 위 임시 좌표 — 표시 전(OnSourceInitialized)에
         재배치되며, 다른 모니터에서 생성되면 DPI 전환 과정에서 창 rect가 요동치는
         문제가 있어 반드시 주 모니터 안에서 생성되게 한다. -->

    <WindowChrome.WindowChrome>
        <WindowChrome GlassFrameThickness="-1" CaptionHeight="0"
                      ResizeBorderThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Border x:Name="Root"
            Padding="16,12,16,14"
            MinWidth="250">

        <Border.ContextMenu>
            <ContextMenu>
                <MenuItem Header="새로 고침" Click="Refresh_Click"/>
                <MenuItem x:Name="TopmostMenu" Header="항상 위" IsCheckable="True" IsChecked="True" Click="Topmost_Click"/>
                <MenuItem x:Name="BusyMenu" Header="점유 상태 표시" IsCheckable="True" IsChecked="True" Click="BusyWatch_Click"/>
                <MenuItem Header="투명도 초기화 (Ctrl+휠로 조절)" Click="ResetTint_Click"/>
                <Separator/>
                <MenuItem x:Name="VersionMenu" IsEnabled="False" FontSize="11"/>
                <MenuItem Header="종료" Click="Exit_Click"/>
            </ContextMenu>
        </Border.ContextMenu>

        <StackPanel>
            <!-- 헤더 -->
            <DockPanel Margin="0,0,0,8">
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding Ports.Count}"
                           Foreground="#7DD3FC" FontSize="12" FontWeight="Bold"
                           VerticalAlignment="Center"/>
                <TextBlock Text="COM PORTS"
                           Foreground="#93A3B8" FontSize="11" FontWeight="Bold"
                           VerticalAlignment="Center"/>
            </DockPanel>

            <!-- 포트 목록 -->
            <ItemsControl x:Name="PortList" ItemsSource="{Binding Ports}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type local:PortInfo}">
                        <StackPanel Orientation="Horizontal" Margin="0,3"
                                    ToolTip="{Binding PnpId}">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8"
                                     Fill="#64748B" VerticalAlignment="Center"/>
                            <TextBlock x:Name="PortNameText"
                                       Text="{Binding PortName}"
                                       Foreground="White" FontFamily="Consolas"
                                       FontSize="14" FontWeight="Bold"
                                       Margin="9,0,0,0" VerticalAlignment="Center"/>
                            <Border x:Name="BusyBadge" Visibility="Collapsed"
                                    Background="#33F59E0B" CornerRadius="4"
                                    Padding="5,1" Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock Text="사용 중" Foreground="#FBBF24"
                                           FontSize="10" FontWeight="Bold"/>
                            </Border>
                            <TextBlock x:Name="DescText"
                                       Text="{Binding Description}"
                                       Foreground="#B8C0CC" FontSize="12"
                                       Margin="10,0,0,0" VerticalAlignment="Center"
                                       MaxWidth="260" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <DataTemplate.Triggers>
                            <!-- 점유 표시는 추가/제거 강조보다 우선순위가 낮다 (뒤 트리거가 이김) -->
                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                <Setter TargetName="StatusDot" Property="Fill" Value="#F59E0B"/>
                                <Setter TargetName="BusyBadge" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Added">
                                <Setter TargetName="StatusDot" Property="Fill" Value="#4ADE80"/>
                                <Setter TargetName="PortNameText" Property="Foreground" Value="#4ADE80"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Status}" Value="Removed">
                                <Setter TargetName="StatusDot" Property="Fill" Value="#F87171"/>
                                <Setter TargetName="PortNameText" Property="Foreground" Value="#F87171"/>
                                <Setter TargetName="PortNameText" Property="TextDecorations" Value="Strikethrough"/>
                                <Setter TargetName="DescText" Property="TextDecorations" Value="Strikethrough"/>
                                <Setter TargetName="DescText" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="BusyBadge" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 포트 없음 -->
            <TextBlock Text="연결된 COM 포트 없음"
                       Foreground="#6B7280" FontSize="12" Margin="0,2,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Ports.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>
    </Border>
</Window>
